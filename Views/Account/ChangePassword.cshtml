@model BiometricAttendanceSystem.Models.ViewModels.ChangePasswordVM
@{
    Layout = null;
    ViewData["Title"] = "Change Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password — @ViewBag.SchoolName</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            background: #f8fafc;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }
        .card {
            background: #fff;
            border-radius: 1.25rem;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 420px;
        }
        .icon { text-align: center; font-size: 2.5rem; margin-bottom: 1rem; }
        h1 { font-size: 1.3rem; font-weight: 700; color: #0f172a; text-align: center; margin-bottom: 0.4rem; }
        .subtitle { font-size: 0.85rem; color: #64748b; text-align: center; margin-bottom: 1.75rem; }
        .notice {
            background: #fefce8; border: 1px solid #fde68a;
            border-radius: 0.6rem; padding: 0.75rem 1rem;
            font-size: 0.85rem; color: #854d0e; margin-bottom: 1.5rem;
        }
        .field { margin-bottom: 1.1rem; }
        label { display: block; font-size: 0.83rem; font-weight: 600; color: #374151; margin-bottom: 0.35rem; }
        input[type="password"],
        input[type="text"] {
            width: 100%; padding: 0.7rem 0.9rem;
            border: 1.5px solid #e2e8f0; border-radius: 0.55rem;
            font-size: 0.95rem; color: #0f172a; outline: none;
            transition: border-color 0.2s;
            box-sizing: border-box;
            font-family: inherit;
        }
        input:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.12); }

        .pw-wrap { position: relative; display: block; }
        .pw-wrap input { padding-right: 2.8rem; width: 100%; box-sizing: border-box; }
        .pw-toggle {
            position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%);
            background: none; border: none; cursor: pointer; padding: 0;
            color: #94a3b8; font-size: 1.1rem; line-height: 1;
            display: flex; align-items: center;
        }
        .pw-toggle:hover { color: #475569; }
        .validation-msg { font-size: 0.78rem; color: #dc2626; margin-top: 0.25rem; }
        .btn {
            width: 100%; padding: 0.8rem;
            background: #2563eb; color: #fff;
            font-size: 1rem; font-weight: 600;
            border: none; border-radius: 0.55rem;
            cursor: pointer; transition: background 0.2s;
        }
        .btn:hover { background: #1d4ed8; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">🔑</div>
        <h1>Set Your Password</h1>
        <p class="subtitle">Set a new password to secure your account.</p>

        <div class="notice">
            ⚠️ Choose a strong password you will remember — you will use it every time you log in.
        </div>

        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CurrentPassword" value="@TempData["TempPassword"]" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="notice" style="background:#fef2f2;border-color:#fecaca;color:#dc2626">
                    @Html.ValidationSummary(false)
                </div>
            }

            <div class="field">
                <label asp-for="NewPassword">New Password</label>
                <div class="pw-wrap">
                    <input asp-for="NewPassword" type="password" autocomplete="new-password" id="newPw" />
                    <button type="button" class="pw-toggle" onclick="togglePw('newPw', this)" tabindex="-1">&#x1F441;</button>
                </div>
                <div class="validation-msg"><span asp-validation-for="NewPassword"></span></div>
            </div>

            <div class="field">
                <label asp-for="ConfirmPassword">Confirm New Password</label>
                <div class="pw-wrap">
                    <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" id="confirmPw" />
                    <button type="button" class="pw-toggle" onclick="togglePw('confirmPw', this)" tabindex="-1">&#x1F441;</button>
                </div>
                <div class="validation-msg"><span asp-validation-for="ConfirmPassword"></span></div>
            </div>

            <button type="submit" class="btn">Set Password &amp; Continue</button>
        </form>
    </div>
<script>
    function togglePw(inputId, btn) {
        const input = document.getElementById(inputId);
        const show = input.type === 'password';
        input.type = show ? 'text' : 'password';
        btn.innerHTML = show ? '<span style="text-decoration:line-through">&#x1F441;</span>' : '&#x1F441;';
    }
</script>
</body>
</html>
