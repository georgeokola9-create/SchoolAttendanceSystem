@model BiometricAttendanceSystem.Models.Department
@{
    ViewData["Title"] = "Edit Department";
}

<h2 style="margin-bottom:20px"><i class="ti ti-edit" style="margin-right:8px;vertical-align:-2px"></i>Edit Department</h2>

<div class="card" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:16px"></div>

            <div class="form-group">
                <label class="form-label">Department Name</label>
                <input asp-for="Name" class="form-control" autofocus />
                <span asp-validation-for="Name" style="font-size:12px;color:var(--red);margin-top:4px;display:block"></span>
            </div>

            <div style="display:flex;gap:10px;margin-top:24px">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-check"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
