@{
    ViewData["Title"] = "Reports";
}

<h2 style="margin-bottom:24px"><i class="ti ti-file-analytics" style="margin-right:8px"></i>Reports</h2>

<div class="report-grid">
    <a asp-action="Daily" class="report-card">
        <div class="report-card-icon" style="background:rgba(34,197,94,.1);color:#22c55e"><i class="ti ti-calendar-day"></i></div>
        <div class="report-card-title">Daily Report</div>
        <div class="report-card-desc">View attendance for a specific day</div>
    </a>

    <a asp-action="Weekly" class="report-card">
        <div class="report-card-icon" style="background:rgba(16,185,129,.1);color:#10b981"><i class="ti ti-calendar-week"></i></div>
        <div class="report-card-title">Weekly Report</div>
        <div class="report-card-desc">Full attendance list for a selected week</div>
    </a>

    <a asp-action="Monthly" class="report-card">
        <div class="report-card-icon" style="background:rgba(59,130,246,.1);color:#3b82f6"><i class="ti ti-calendar-month"></i></div>
        <div class="report-card-title">Monthly Report</div>
        <div class="report-card-desc">Teacher attendance summary for a month</div>
    </a>

    <a asp-action="Individual" class="report-card">
        <div class="report-card-icon" style="background:rgba(245,158,11,.1);color:#f59e0b"><i class="ti ti-user-circle"></i></div>
        <div class="report-card-title">Individual Report</div>
        <div class="report-card-desc">Attendance history for a specific teacher</div>
    </a>

    <a asp-action="Department" class="report-card">
        <div class="report-card-icon" style="background:rgba(99,102,241,.1);color:#6366f1"><i class="ti ti-building"></i></div>
        <div class="report-card-title">Department Report</div>
        <div class="report-card-desc">Department-wide attendance metrics</div>
    </a>
</div>
