@model BiometricAttendanceSystem.Models.ViewModels.WeeklyReportVM
@{
    Layout = "~/Views/Shared/_PrintLayout.cshtml";

    var weekStart = Model?.WeekStart ?? DateTime.Today;
    var weekEnd = Model?.WeekEnd ?? DateTime.Today;
    var weekNumber = Model?.WeekNumber ?? 0;

    var records = Model?.Records ?? new List<BiometricAttendanceSystem.Models.AttendanceRecord>();

    ViewBag.Title = $"Weekly Report – Week {weekNumber}";
}

<h1>Weekly Attendance Report</h1>
<h2>@weekStart.ToString("dd MMM") – @weekEnd.ToString("dd MMM yyyy") &nbsp;·&nbsp; Week @weekNumber</h2>

<table>
    <thead>
        <tr>
            <th>#</th>
            <th>Date</th>
            <th>Name</th>
            <th>National ID</th>
            <th>Department</th>
            <th>Check-In</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @{
            var i = 1;
        }

        @foreach (var r in records.OrderBy(x => x.Date).ThenBy(x => x.Teacher?.FullName))
        {
            <tr>
                <td>@(i++)</td>
                <td>@r.Date.ToString("ddd, dd MMM yyyy")</td>
                <td>@(r.Teacher?.FullName ?? "-")</td>
                <td>@(r.Teacher?.NationalId ?? "-")</td>
                <td>@(r.Teacher?.Department?.Name ?? "—")</td>
                <td>@(r.CheckInDisplay ?? "-")</td>
                <td>
                    <span class="badge badge-@r.Status.ToString().ToLower()">
                        @r.Status
                    </span>
                </td>
            </tr>
        }

        @if (!records.Any())
        {
            <tr>
                <td colspan="7" style="text-align:center;color:#666;padding:12px">
                    No records found.
                </td>
            </tr>
        }
    </tbody>
</table>
