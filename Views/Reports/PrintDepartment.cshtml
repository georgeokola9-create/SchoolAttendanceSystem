@model BiometricAttendanceSystem.Models.ViewModels.DepartmentReportVM
@{
    Layout = "~/Views/Shared/_PrintLayout.cshtml";

    var dept = Model?.Department;
    var from = Model?.From ?? DateTime.Today;
    var to = Model?.To ?? DateTime.Today;
    var summaries = Model?.Summaries ?? new List<BiometricAttendanceSystem.Models.ViewModels.MonthlyTeacherSummary>();

    ViewBag.Title = $"Department Report – {dept?.Name ?? "Department"}";
}

<h1>Department Attendance Report</h1>
<h2>@(dept?.Name ?? "Department") &nbsp;·&nbsp; @from.ToString("dd MMM yyyy") – @to.ToString("dd MMM yyyy")</h2>

<table>
    <thead>
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>National ID</th>
            <th>Present</th>
            <th>Late</th>
            <th>Absent</th>
            <th>Working Days</th>
            <th>Attendance %</th>
        </tr>
    </thead>
    <tbody>
        @{
            var i = 1;
        }

        @if (summaries != null && summaries.Count > 0)
        {
            @foreach (var s in summaries)
            {
                <tr>
                    <td>@(i++)</td>
                    <td>@(s?.Teacher?.FullName ?? "-")</td>
                    <td>@(s?.Teacher?.NationalId ?? "-")</td>
                    <td>@(s?.PresentDays ?? 0)</td>
                    <td>@(s?.LateDays ?? 0)</td>
                    <td>@(s?.AbsentDays ?? 0)</td>
                    <td>@(s?.WorkingDays ?? 0)</td>
                    <td>@((s?.AttendancePercentage ?? 0).ToString("0.0"))%</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" style="text-align:center;color:#666;padding:12px">
                    No records found.
                </td>
            </tr>
        }
    </tbody>
</table>
