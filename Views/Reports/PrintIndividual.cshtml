@model BiometricAttendanceSystem.Models.ViewModels.TeacherHistoryVM
@{
    Layout = "~/Views/Shared/_PrintLayout.cshtml";

    var teacher = Model?.Teacher;
    var from = Model?.From ?? DateTime.Today;
    var to = Model?.To ?? DateTime.Today;
    List<BiometricAttendanceSystem.Models.AttendanceRecord> records = Model?.Records ?? new List<BiometricAttendanceSystem.Models.AttendanceRecord>();

    ViewBag.Title = $"Attendance History – {teacher?.FullName ?? "Teacher"}";
}

<h1>Attendance History</h1>
<h2>@(teacher?.FullName ?? "Teacher") &nbsp;·&nbsp; @from.ToString("dd MMM yyyy") – @to.ToString("dd MMM yyyy")</h2>

<div class="meta">
    National ID: @(teacher?.NationalId ?? "-") &nbsp;|&nbsp;
    Department: @(teacher?.Department?.Name ?? "—")
</div>

<div class="summary-grid">
    <div class="summary-box">
        <div class="value">@((Model?.PresentDays ?? 0).ToString())</div>
        <div class="label">Present</div>
    </div>
    <div class="summary-box">
        <div class="value">@((Model?.LateDays ?? 0).ToString())</div>
        <div class="label">Late</div>
    </div>
    <div class="summary-box">
        <div class="value">@((Model?.AbsentDays ?? 0).ToString())</div>
        <div class="label">Absent</div>
    </div>
    <div class="summary-box">
        <div class="value">@((Model?.AttendancePercentage ?? 0).ToString("0.0"))%</div>
        <div class="label">Attendance</div>
    </div>
</div>

<table>
    <thead>
        <tr>
            <th>Date</th>
            <th>Day</th>
            <th>Check-In</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @{
            var hasAny = records != null && records.Count > 0;
        }

        @if (hasAny)
        {
            @foreach (var r in (records ?? new List<BiometricAttendanceSystem.Models.AttendanceRecord>()).OrderByDescending(x => x.Date))
            {
                <tr>
                    <td>@r.Date.ToString("dd MMM yyyy")</td>
                    <td>@r.Date.ToString("dddd")</td>
                    <td>@(r.CheckInDisplay ?? "-")</td>
                    <td>
                        <span class="badge badge-@r.Status.ToString().ToLower()">
                            @r.Status
                        </span>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" style="text-align:center;color:#666;padding:12px">
                    No records found.
                </td>
            </tr>
        }
    </tbody>
</table>
