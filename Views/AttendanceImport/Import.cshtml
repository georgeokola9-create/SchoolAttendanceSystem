@{
    ViewData["Title"] = "Bulk CSV Import";
    Layout = "_Layout";
}

<div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.5rem; gap:1rem;">
    <div>
        <h4 style="margin:0 0 0.25rem 0; font-size:1.25rem; font-weight:600; color:var(--text-primary);">Bulk CSV Import</h4>
        <p style="margin:0; font-size:0.875rem; color:var(--text-muted);">Upload a CSV file to import historical attendance records.</p>
    </div>
    <a asp-controller="AttendanceImport" asp-action="Manual" class="btn btn-ghost btn-sm" style="white-space:nowrap; flex-shrink:0;">
        ✏️ Manual Entry
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger" style="margin-bottom:1rem;">@Html.ValidationSummary()</div>
}

<style>
    @@media (max-width: 768px) {
        .import-grid { grid-template-columns: 1fr !important; }
    }
</style>

<div class="import-grid" style="display:grid; grid-template-columns:1fr 340px; gap:1.25rem; align-items:start;">

@* Upload card *@
    <div class="card">
        <div class="card-header">
            <span class="card-title">Upload CSV File</span>
        </div>
        <div class="card-body" style="padding:1.5rem;">
            <form method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Select File</label>
                    <input type="file"
                           name="csvFile"
                           class="form-control"
                           accept=".csv"
                           required />
                    <p style="margin:0.375rem 0 0 0; font-size:0.8rem; color:var(--text-muted);">Only .csv files are accepted.</p>
                </div>

                <div style="margin-top:1.25rem; display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
                    <button type="submit" class="btn btn-primary">
                        ⬆ Upload and Import
                    </button>
                    <a asp-controller="AttendanceImport"
                       asp-action="DownloadTemplate"
                       class="btn btn-ghost btn-sm">
                        ⬇ Download CSV Template
                    </a>
                </div>
            </form>
        </div>
    </div>

    @* Format guide card *@
    <div class="card" style="border-color:var(--accent-blue, rgba(59,130,246,0.4));">
        <div class="card-header" style="border-bottom:1px solid var(--border-color);">
            <span class="card-title" style="color:var(--accent-blue, #60a5fa);">📋 CSV Format Guide</span>
        </div>
        <div class="card-body" style="padding:1.25rem;">

            <p style="margin:0 0 0.75rem 0; font-size:0.825rem; color:var(--text-muted);">Your CSV must have these columns in this order:</p>

            <div class="table-wrapper" style="margin-bottom:1rem;">
                <table class="att-table" style="font-size:0.825rem;">
                    <thead>
                        <tr>
                            <th>Column</th>
                            <th>Format / Example</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td style="font-weight:600;">Date</td><td style="color:var(--text-muted);">05/01/2026</td></tr>
                        <tr><td style="font-weight:600;">Teacher</td><td style="color:var(--text-muted);">James Mwangi <em>or</em> 12345678</td></tr>
                        <tr><td style="font-weight:600;">Status</td><td style="color:var(--text-muted);">Present, Late, or Absent</td></tr>
                        <tr><td style="font-weight:600;">Check-In Time <em style="font-weight:400;">(optional)</em></td><td style="color:var(--text-muted);">07:45</td></tr>
                    </tbody>
                </table>
            </div>

            <p style="margin:0 0 0.5rem 0; font-size:0.825rem; color:var(--text-muted);">Example rows:</p>
            <pre style="background:var(--bg-hover, rgba(255,255,255,0.04)); border:1px solid var(--border-color); border-radius:6px; padding:0.75rem; font-size:0.775rem; color:var(--text-secondary, #94a3b8); margin:0 0 1rem 0; overflow-x:auto; white-space:pre;">05/01/2026,James Mwangi,Present,07:45
05/01/2026,Mary Otieno,Late,09:20
05/01/2026,12345678,Absent,</pre>

            <ul style="margin:0; padding-left:1.1rem; font-size:0.8rem; color:var(--text-muted); line-height:1.7;">
                <li>First row is treated as a header and skipped</li>
                <li>Teacher matched by full name or National ID</li>
                <li>Existing records for the same date will be <strong style="color:var(--text-primary);">updated</strong></li>
                <li>Blank rows are ignored</li>
            </ul>

        </div>
    </div>

</div>


