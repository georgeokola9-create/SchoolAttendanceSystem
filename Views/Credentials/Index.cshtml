@using BiometricAttendanceSystem.Models
@model List<Teacher>
@{
    ViewData["Title"] = "Teacher Credentials";
    var lastId     = TempData["LastTeacherId"] as int?;
    var success    = TempData["Success"] as string;
    var error      = TempData["Error"] as string;
    var newTeacher   = TempData["NewTeacher"] as string;
    var emailStatus  = TempData["EmailStatus"] as string;

    var withCreds    = Model.Count(t => t.CredentialsCreatedAt.HasValue);
    var withDevice   = Model.Count(t => t.RegisteredDeviceId != null);
    var withoutCreds = Model.Count(t => !t.CredentialsCreatedAt.HasValue);
}

<style>
    .cred-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 20px;
    }

    .cred-stat {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .cred-stat-icon {
        width: 38px;
        height: 38px;
        border-radius: var(--radius-md);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .cred-stat-icon.green  { background: var(--green-soft);  color: var(--green); }
    .cred-stat-icon.amber  { background: var(--amber-soft);  color: var(--amber); }
    .cred-stat-icon.indigo { background: var(--indigo-soft); color: var(--indigo); }

    .cred-stat-val  { font-size: 22px; font-weight: 800; line-height: 1; }
    .cred-stat-lbl  { font-size: 11px; color: var(--text-muted); margin-top: 3px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }

    .cred-table     { min-width: 860px; }
    .cred-table .teacher-col   { width: 24%; }
    .cred-table .tsc-col       { width: 13%; }
    .cred-table .dept-col      { width: 14%; }
    .cred-table .user-col      { width: 13%; }
    .cred-table .creds-col     { width: 14%; }
    .cred-table .device-col    { width: 14%; }
    .cred-table .action-col    { width: 8%; }

    .mono-cell {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-secondary);
    }

    .badge-active {
        background: var(--green-soft);
        color: #86efac;
        border: 1px solid rgba(34, 197, 94, 0.25);
    }
    .badge-active::before { background: var(--green); }

    .badge-none {
        background: rgba(126,149,184,.1);
        color: var(--text-muted);
        border: 1px solid var(--border);
    }
    .badge-none::before { background: var(--text-muted); }

    .badge-device {
        background: var(--indigo-soft);
        color: #c7d2fe;
        border: 1px solid rgba(99, 102, 241, 0.25);
    }
    .badge-device::before { background: var(--indigo); }

    .badge-no-device {
        background: var(--amber-soft);
        color: #fcd34d;
        border: 1px solid rgba(245, 158, 11, 0.25);
    }
    .badge-no-device::before { background: var(--amber); }

    .success-banner {
        background: var(--green-soft);
        border: 1px solid rgba(34, 197, 94, 0.25);
        border-radius: var(--radius-lg);
        padding: 14px 18px;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .success-banner-body {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        min-width: 0;
    }

    .success-banner-icon {
        color: var(--green);
        font-size: 18px;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .success-banner-title {
        font-weight: 700;
        font-size: 13px;
        color: #86efac;
        margin-bottom: 4px;
    }

    .success-banner-msg {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-secondary);
        word-break: break-all;
    }
</style>

<!-- Page header -->
<div class="topbar-title" style="margin-bottom:20px">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
        <div>
            <div style="font-size:18px;font-weight:800">Teacher Credentials</div>
            <div style="font-size:12px;color:var(--text-muted);margin-top:3px">Manage login credentials and device registration</div>
        </div>
        <a asp-controller="Credentials" asp-action="DownloadAll" class="btn btn-ghost">
            <i class="ti ti-file-download"></i> Download All Slips
        </a>
    </div>
</div>

<!-- Stats row -->
<div class="cred-stats">
    <div class="cred-stat">
        <div class="cred-stat-icon green"><i class="ti ti-key"></i></div>
        <div>
            <div class="cred-stat-val">@withCreds</div>
            <div class="cred-stat-lbl">Credentials Set</div>
        </div>
    </div>
    <div class="cred-stat">
        <div class="cred-stat-icon amber"><i class="ti ti-key-off"></i></div>
        <div>
            <div class="cred-stat-val">@withoutCreds</div>
            <div class="cred-stat-lbl">No Credentials</div>
        </div>
    </div>
    <div class="cred-stat">
        <div class="cred-stat-icon indigo"><i class="ti ti-device-mobile"></i></div>
        <div>
            <div class="cred-stat-val">@withDevice</div>
            <div class="cred-stat-lbl">Devices Registered</div>
        </div>
    </div>
</div>

<!-- Alerts -->
@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger" style="margin-bottom:16px">
        <i class="ti ti-alert-circle"></i> @error
    </div>
}

@if (!string.IsNullOrEmpty(success) && lastId.HasValue)
{
    var slipTeacher = Model.FirstOrDefault(t => t.Id == lastId.Value);
    var slipName    = slipTeacher != null
        ? slipTeacher.FullName.ToLower().Replace(" ", "-")
        : $"teacher-{lastId.Value}";

    <div class="success-banner">
        <div class="success-banner-body">
            <i class="ti ti-circle-check success-banner-icon"></i>
            <div>
                <div class="success-banner-title">
                    @(string.IsNullOrEmpty(newTeacher)
                        ? "Credentials set — slip downloading automatically."
                        : $"{newTeacher} registered & credentials set — slip downloading automatically.")
                </div>
                <div class="success-banner-msg">@success</div>
                @if (!string.IsNullOrEmpty(emailStatus))
                {
                    <div style="font-size:12px;margin-top:4px;color:var(--text-muted)">
                        <i class="ti ti-mail"></i> @emailStatus
                    </div>
                }
            </div>
        </div>
        <a id="autoSlipLink"
           asp-controller="Credentials" asp-action="DownloadSlip" asp-route-teacherId="@lastId"
           download="credentials-@(slipName).pdf"
           class="btn btn-primary btn-sm" style="flex-shrink:0">
            <i class="ti ti-download"></i> Download Again
        </a>
    </div>
}

<!-- Table -->
<div class="card table-card">
    <div class="card-header">
        <span class="card-title">
            <span class="card-title-icon"><i class="ti ti-shield-lock"></i></span>
            All Teachers (@Model.Count)
        </span>

        <div class="srch-wrap" style="margin-left:auto;width:280px;display:inline-flex;align-items:center;gap:6px">
            <i class="ti ti-search srch-icon" style="flex-shrink:0"></i>
            <input type="text" id="credSearch" class="srch" placeholder="Search name, TSC, department..." style="width:100%;min-width:0" />
        </div>
    </div>

    <div class="table-wrapper">
        <table class="att-table cred-table" id="credTable">
            <colgroup>
                <col class="teacher-col" />
                <col class="tsc-col" />
                <col class="dept-col" />
                <col class="user-col" />
                <col class="creds-col" />
                <col class="device-col" />
                <col class="action-col" />
            </colgroup>
            <thead>
                <tr>
                    <th>Teacher</th>
                    <th>National ID</th>
                    <th>Department</th>
                    <th>Username</th>
                    <th>Credentials</th>
                    <th>Device</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    var initials = string.Concat(
                        t.FullName.Split(' ')
                         .Where(w => w.Length > 0)
                         .Take(2)
                         .Select(w => w[0].ToString())
                    ).ToUpper();

                    <tr>
                        <td>
                            <div class="teacher-cell">
                                <div class="teacher-avatar">@initials</div>
                                <div>
                                    <div class="teacher-name">@t.FullName</div>
                                    <div class="teacher-tsc">@t.Department?.Name</div>
                                </div>
                            </div>
                        </td>
                        <td class="mono-cell">@t.NationalId</td>
                        <td><span class="dept-tag">@(t.Department?.Name ?? "—")</span></td>
                        <td class="mono-cell">
                            @if (t.Username != null)
                            {
                                @t.Username
                            }
                            else
                            {
                                <span style="color:var(--text-muted)">Not set</span>
                            }
                        </td>
                        <td>
                            @if (t.CredentialsCreatedAt.HasValue)
                            {
                                <span class="badge badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-none">None</span>
                            }
                        </td>
                        <td>
                            @if (t.RegisteredDeviceId != null)
                            {
                                <span class="badge badge-device">Registered</span>
                            }
                            else
                            {
                                <span class="badge badge-no-device">None</span>
                            }
                        </td>
                        <td>
                            <div class="cell-actions">
                                <form class="cred-form" asp-controller="Credentials" asp-action="SetCredentials" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="teacherId" value="@t.Id" />
                                    <button type="button" class="btn btn-ghost btn-sm"
                                            title="@(t.Username == null ? "Set credentials" : "Reset password")"
                                            onclick="credConfirm(this, '@t.FullName', @(t.Username == null ? "true" : "false"))">
                                        <i class="ti ti-@(t.Username == null ? "key" : "refresh")"></i>
                                        @(t.Username == null ? "Set" : "Reset")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<!-- Confirm Modal -->
<div id="credModal" style="display:none;position:fixed;inset:0;z-index:1000;align-items:center;justify-content:center">
    <div id="credModalBackdrop" style="position:absolute;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(2px)"></div>
    <div style="position:relative;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px 28px;width:100%;max-width:380px;margin:16px;box-shadow:0 20px 60px rgba(0,0,0,.4)">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
            <div style="width:36px;height:36px;border-radius:var(--radius-md);background:var(--amber-soft);color:var(--amber);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">
                <i class="ti ti-key"></i>
            </div>
            <div>
                <div id="credModalTitle" style="font-weight:700;font-size:14px"></div>
                <div id="credModalSub" style="font-size:12px;color:var(--text-muted);margin-top:2px"></div>
            </div>
        </div>
        <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:20px">
            <button type="button" class="btn btn-ghost btn-sm" onclick="credModalClose()">Cancel</button>
            <button type="button" id="credModalConfirm" class="btn btn-primary btn-sm">Confirm</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Auto-download slip if credentials were just set
    const autoLink = document.getElementById('autoSlipLink');
    if (autoLink) {
        setTimeout(() => autoLink.click(), 600);
    }

    // Search filter
    document.getElementById('credSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#credTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });

    // Confirm modal
    let _pendingForm = null;

    function credConfirm(btn, name, isNew) {
        _pendingForm = btn.closest('form');
        const modal = document.getElementById('credModal');
        document.getElementById('credModalTitle').textContent = isNew === true || isNew === 'true'
            ? 'Set credentials for ' + name + '?'
            : 'Reset password for ' + name + '?';
        document.getElementById('credModalSub').textContent = isNew === true || isNew === 'true'
            ? 'A new username and password will be generated.'
            : 'The existing password will be replaced. Print the new slip immediately.';
        modal.style.display = 'flex';
    }

    function credModalClose() {
        document.getElementById('credModal').style.display = 'none';
        _pendingForm = null;
    }

    document.getElementById('credModalConfirm').addEventListener('click', function () {
        if (_pendingForm) {
            const form = _pendingForm;
            credModalClose();
            form.submit();
        }
    });

    document.getElementById('credModalBackdrop').addEventListener('click', credModalClose);

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') credModalClose();
    });
</script>
}
