@using BiometricAttendanceSystem.Models
@model BiometricAttendanceSystem.Models.ViewModels.TeacherHistoryVM
@{
    Layout = null;
    ViewData["Title"] = "My Attendance";
    var today = Model.Records.FirstOrDefault(r => r.Date == DateTime.Today);
    var hasDevice = Model.Teacher.RegisteredDeviceId != null;
    var initial = Model.Teacher.FullName?.Substring(0, 1).ToUpper() ?? "?";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Attendance — @ViewBag.SchoolName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --green:   #16a34a;
            --green-bg:#dcfce7;
            --yellow:  #b45309;
            --yellow-bg:#fef9c3;
            --red:     #dc2626;
            --red-bg:  #fee2e2;
            --blue:    #2563eb;
            --blue-bg: #eff6ff;
            --border:  #e2e8f0;
            --text:    #0f172a;
            --muted:   #64748b;
            --bg:      #f1f5f9;
            --white:   #ffffff;
            --radius:  14px;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Top bar ── */
        .topbar {
            position: sticky;
            top: 0;
            z-index: 10;
            background: var(--white);
            border-bottom: 1px solid var(--border);
            padding: 0 16px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .topbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
            font-size: 15px;
        }

        .topbar-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--blue);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }

        .topbar-name {
            font-size: 14px;
            font-weight: 600;
            line-height: 1.2;
            max-width: 160px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .topbar-role {
            font-size: 11px;
            color: var(--muted);
            font-weight: 500;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 13px;
            font-weight: 600;
            color: var(--muted);
            background: none;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: 6px 12px;
            cursor: pointer;
            text-decoration: none;
            white-space: nowrap;
        }

        /* ── Page body ── */
        .page { padding: 16px; max-width: 520px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px; }

        /* ── Today card ── */
        .today-card {
            border-radius: var(--radius);
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .today-card.present  { background: var(--green-bg);  border: 1.5px solid #bbf7d0; }
        .today-card.late     { background: var(--yellow-bg); border: 1.5px solid #fde68a; }
        .today-card.absent   { background: var(--red-bg);    border: 1.5px solid #fecaca; }
        .today-card.none     { background: var(--white);     border: 1.5px solid var(--border); }

        .today-left { display: flex; flex-direction: column; gap: 3px; }

        .today-label {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
            opacity: .7;
        }

        .today-status {
            font-size: 22px;
            font-weight: 800;
            line-height: 1.1;
        }

        .today-card.present .today-status { color: var(--green); }
        .today-card.late    .today-status { color: var(--yellow); }
        .today-card.absent  .today-status { color: var(--red); }
        .today-card.none    .today-status { color: var(--muted); }

        .today-time {
            font-size: 13px;
            color: var(--muted);
            margin-top: 2px;
        }

        .today-icon {
            font-size: 36px;
            opacity: .5;
            flex-shrink: 0;
        }

        /* ── Device banner ── */
        .device-banner {
            background: var(--blue-bg);
            border: 1.5px solid #bfdbfe;
            border-radius: var(--radius);
            padding: 14px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            font-size: 13px;
            color: #1e40af;
        }

        .device-banner-text { display: flex; align-items: center; gap: 8px; font-weight: 500; }

        .device-banner a {
            font-weight: 700;
            color: var(--blue);
            text-decoration: none;
            white-space: nowrap;
            font-size: 13px;
            padding: 6px 12px;
            background: var(--blue);
            color: #fff;
            border-radius: 8px;
        }

        .device-ok {
            background: var(--green-bg);
            border: 1.5px solid #bbf7d0;
            color: #166534;
        }

        .device-ok .device-banner-text { color: #166534; }

        /* ── Stats row ── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

        .stat-card {
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            padding: 14px 8px;
            text-align: center;
        }

        .stat-num { font-size: 24px; font-weight: 800; line-height: 1; }
        .stat-lbl { font-size: 10px; font-weight: 600; color: var(--muted); margin-top: 4px; text-transform: uppercase; letter-spacing: .04em; }

        .stat-present .stat-num { color: var(--green); }
        .stat-late    .stat-num { color: var(--yellow); }
        .stat-absent  .stat-num { color: var(--red); }
        .stat-rate    .stat-num { color: var(--blue); }

        /* ── Filter ── */
        .filter-card {
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            padding: 14px 16px;
            display: flex;
            gap: 10px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .filter-card label { font-size: 11px; font-weight: 700; color: var(--muted); display: block; margin-bottom: 5px; text-transform: uppercase; letter-spacing: .05em; }

        .filter-card input {
            width: 100%;
            padding: 9px 11px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            background: var(--bg);
            color: var(--text);
            outline: none;
        }

        .filter-card input:focus { border-color: var(--blue); background: var(--white); }
        .filter-card .fg { flex: 1; min-width: 120px; }

        .filter-btn {
            padding: 10px 18px;
            background: var(--blue);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            white-space: nowrap;
            flex-shrink: 0;
        }

        /* ── Record list ── */
        .section-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .06em;
            padding: 0 2px;
        }

        .record-list { display: flex; flex-direction: column; gap: 8px; }

        .record-row {
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            padding: 13px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .record-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .dot-present { background: var(--green); }
        .dot-late    { background: #eab308; }
        .dot-absent  { background: var(--red); }

        .record-info { flex: 1; min-width: 0; }
        .record-date { font-weight: 700; font-size: 14px; }
        .record-day  { font-size: 12px; color: var(--muted); margin-top: 1px; }
        .record-time { font-size: 13px; color: var(--muted); flex-shrink: 0; }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 99px;
            font-size: 11px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .badge-present { background: var(--green-bg); color: #15803d; }
        .badge-late    { background: var(--yellow-bg); color: #92400e; }
        .badge-absent  { background: var(--red-bg); color: var(--red); }

        .empty {
            text-align: center;
            padding: 40px 20px;
            color: var(--muted);
            font-size: 14px;
            background: var(--white);
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
        }

        .empty-icon { font-size: 32px; margin-bottom: 8px; opacity: .4; }

        /* ── Bottom padding for phones ── */
        .page-end { height: 32px; }

        @@media (max-width: 400px) {
            .stats-row { grid-template-columns: repeat(2, 1fr); }
            .today-status { font-size: 18px; }
        }
    </style>
</head>
<body>

    <!-- Top bar -->
    <header class="topbar">
        <div class="topbar-brand">
            <div class="topbar-avatar">@initial</div>
            <div>
                <div class="topbar-name">@Model.Teacher.FullName</div>
                <div class="topbar-role">Teacher</div>
            </div>
        </div>
        <form method="post" action="/Account/Logout" style="margin:0">
            @Html.AntiForgeryToken()
            <button type="submit" class="logout-btn">Sign out</button>
        </form>
    </header>

    <div class="page">

        <!-- Today's status -->
        @{
            string todayClass, todayStatusText, todayIcon;
            string todayTimeText = "";

            if (today == null)
            {
                todayClass = "none"; todayStatusText = "Not checked in yet"; todayIcon = "⏳";
            }
            else if (today.Status == AttendanceStatus.Present)
            {
                todayClass = "present"; todayStatusText = "Present"; todayIcon = "✅";
                todayTimeText = today.CheckInTime.HasValue ? "Checked in at " + DateTime.Today.Add(today.CheckInTime.Value).ToString("hh:mm tt") : "";
            }
            else if (today.Status == AttendanceStatus.Late)
            {
                todayClass = "late"; todayStatusText = "Late"; todayIcon = "⚠️";
                todayTimeText = today.CheckInTime.HasValue ? "Checked in at " + DateTime.Today.Add(today.CheckInTime.Value).ToString("hh:mm tt") : "";
            }
            else
            {
                todayClass = "absent"; todayStatusText = "Absent"; todayIcon = "❌";
            }
        }

        <div class="today-card @todayClass">
            <div class="today-left">
                <div class="today-label">Today — @DateTime.Today.ToString("dddd, dd MMM")</div>
                <div class="today-status">@todayStatusText</div>
                @if (!string.IsNullOrEmpty(todayTimeText))
                {
                    <div class="today-time">@todayTimeText</div>
                }
            </div>
            <div class="today-icon">@todayIcon</div>
        </div>

        <!-- Device status -->
        @if (!hasDevice)
        {
            <div class="device-banner">
                <div class="device-banner-text">
                    <span>📱</span>
                    <span>Register your device to enable QR check-in</span>
                </div>
                <a href="/Qr/RegisterDevice">Register →</a>
            </div>
        }
        else
        {
            <div class="device-banner device-ok">
                <div class="device-banner-text">
                    <span>✅</span>
                    <span>Device registered — QR check-in enabled</span>
                </div>
                <a href="/Qr/RegisterDevice" style="background:#16a34a">Re-register</a>
            </div>
        }

        <!-- Summary stats -->
        <div class="stats-row">
            <div class="stat-card stat-present">
                <div class="stat-num">@Model.PresentDays</div>
                <div class="stat-lbl">Present</div>
            </div>
            <div class="stat-card stat-late">
                <div class="stat-num">@Model.LateDays</div>
                <div class="stat-lbl">Late</div>
            </div>
            <div class="stat-card stat-absent">
                <div class="stat-num">@Model.AbsentDays</div>
                <div class="stat-lbl">Absent</div>
            </div>
            <div class="stat-card stat-rate">
                <div class="stat-num">@Model.AttendancePercentage%</div>
                <div class="stat-lbl">Rate</div>
            </div>
        </div>

        <!-- Date filter -->
        <form method="get" class="filter-card">
            <div class="fg">
                <label>From</label>
                <input type="date" name="from" value="@Model.From.ToString("yyyy-MM-dd")" />
            </div>
            <div class="fg">
                <label>To</label>
                <input type="date" name="to" value="@Model.To.ToString("yyyy-MM-dd")" />
            </div>
            <button type="submit" class="filter-btn">Filter</button>
        </form>

        <!-- Record list -->
        <div class="section-title">Attendance History</div>

        @if (!Model.Records.Any())
        {
            <div class="empty">
                <div class="empty-icon">📭</div>
                No records found for this period.
            </div>
        }
        else
        {
            <div class="record-list">
                @foreach (var r in Model.Records.OrderByDescending(x => x.Date))
                {
                    var dotClass = r.Status == AttendanceStatus.Present ? "dot-present"
                                 : r.Status == AttendanceStatus.Late    ? "dot-late"
                                 : "dot-absent";
                    var badgeClass = "badge-" + r.Status.ToString().ToLower();
                    <div class="record-row">
                        <div class="record-dot @dotClass"></div>
                        <div class="record-info">
                            <div class="record-date">@r.Date.ToString("dd MMM yyyy")</div>
                            <div class="record-day">@r.Date.ToString("dddd")</div>
                        </div>
                        <div class="record-time">
                            @(r.CheckInTime.HasValue ? DateTime.Today.Add(r.CheckInTime.Value).ToString("hh:mm tt") : "—")
                        </div>
                        <span class="badge @badgeClass">@r.Status</span>
                    </div>
                }
            </div>
        }

        <div class="page-end"></div>
    </div>
</body>
</html>
