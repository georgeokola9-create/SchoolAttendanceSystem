@using BiometricAttendanceSystem.Models
@model Teacher
@{
    ViewData["Title"] = "Remove Teacher";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
    <h2><i class="ti ti-user-minus" style="margin-right:8px;vertical-align:-2px"></i>Remove Teacher</h2>
    <a asp-action="Index" class="btn btn-ghost">
        <i class="ti ti-arrow-left"></i> Back to All Teachers
    </a>
</div>

<div class="card" style="max-width:600px">
    <div class="card-header">
        <span class="card-title">
            <span class="card-title-icon" style="background:var(--red-soft);color:var(--red)">
                <i class="ti ti-alert-triangle"></i>
            </span>
            Confirm Removal
        </span>
    </div>
    <div class="card-body">

        <div style="display:flex;align-items:center;gap:16px;padding:16px;background:var(--bg-input);border-radius:var(--radius-md);margin-bottom:20px">
            <div class="teacher-avatar" style="width:48px;height:48px;font-size:16px;flex:0 0 auto">
                @string.Concat(Model.FullName.Split(' ').Select(w => w.FirstOrDefault())).Substring(0, Math.Min(2, Model.FullName.Split(' ').Length)).ToUpper()
            </div>
            <div>
                <div style="font-weight:700;font-size:15px">@Model.FullName</div>
                <div style="font-size:12px;color:var(--text-muted);font-family:var(--font-mono)">@Model.NationalId</div>
                <div style="font-size:12px;color:var(--text-secondary);margin-top:2px">@Model.Department?.Name</div>
            </div>
        </div>

        <div class="alert alert-danger" style="margin-bottom:20px">
            <i class="ti ti-info-circle" style="font-size:16px"></i>
            <div>
                <strong>This action is permanent and cannot be undone.</strong>
                <ul style="margin:8px 0 0 16px;padding:0;font-weight:400">
                    <li>@Model.FullName will be removed from active staff immediately</li>
                    <li>They will no longer appear on the dashboard or reports</li>
                    <li>All attendance records are retained and accessible under Former Employees</li>
                </ul>
            </div>
        </div>

        <div style="display:flex;gap:10px">
            <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger" style="min-width:160px;justify-content:center">
                    <i class="ti ti-user-minus"></i> Yes, Remove Teacher
                </button>
            </form>
            <a asp-action="Index" class="btn btn-ghost">
                Cancel
            </a>
        </div>

    </div>
</div>
