@using BiometricAttendanceSystem.Models.ViewModels
@model TeacherRegisterVM
@{
    ViewData["Title"] = "Edit Teacher";
}

<h2 style="margin-bottom:20px"><i class="ti ti-edit" style="margin-right:8px"></i>Edit Teacher</h2>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Teacher.Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:16px"></div>

            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input asp-for="Teacher.FullName" class="form-control" />
                <span asp-validation-for="Teacher.FullName" style="font-size:12px;color:var(--red)"></span>
            </div>

            <div class="form-group">
                <label class="form-label">National ID</label>
                <input asp-for="Teacher.NationalId" class="form-control" />
                <span asp-validation-for="Teacher.NationalId" style="font-size:12px;color:var(--red)"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Department</label>
                <select asp-for="Teacher.DepartmentId" class="form-select" asp-items="@(new SelectList(Model.Departments, "Id", "Name"))">
                    <option value="">-- Select Department --</option>
                </select>
                <span asp-validation-for="Teacher.DepartmentId" style="font-size:12px;color:var(--red)"></span>
            </div>

            <div style="display:flex;gap:10px;margin-top:24px">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-check"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
