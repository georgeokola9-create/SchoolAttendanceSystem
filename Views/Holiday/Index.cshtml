@using BiometricAttendanceSystem.Models
@model List<Holiday>
@{
    ViewData["Title"] = "Manage Holidays & School Breaks";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
    <h2><i class="ti ti-calendar-x" style="margin-right:8px;vertical-align:-2px"></i>Holidays & School Breaks</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="ti ti-plus"></i> Add Holiday
    </a>
</div>

<div class="alert alert-success" style="margin-bottom:20px">
    <i class="ti ti-info-circle" style="margin-right:8px"></i>
    <strong>How it works:</strong> Days marked as holidays are excluded from working day counts in monthly reports.
</div>

@if (Model?.Count > 0)
{
    <div class="card">
        <div class="card-header">
            <span class="card-title">
                <span class="card-title-icon"><i class="ti ti-calendar-x"></i></span>
                Total Holidays: @Model.Count
            </span>
        </div>
        <div class="table-wrapper">
            <table class="att-table">
                <thead>
                    <tr>
                        <th>Holiday Name</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Duration</th>
                        <th>Description</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var h in Model.OrderBy(x => x.StartDate))
                {
                    var duration = (h.EndDate.Date - h.StartDate.Date).Days + 1;
                    <tr>
                        <td><div style="font-weight:600">@h.Name</div></td>
                        <td class="tmono" style="font-size:12px">@h.StartDate.ToString("dd MMM yyyy")</td>
                        <td class="tmono" style="font-size:12px">@h.EndDate.ToString("dd MMM yyyy")</td>
                        <td><span class="badge badge-late">@duration days</span></td>
                        <td style="color:var(--text-muted);font-size:12px">@(string.IsNullOrEmpty(h.Description) ? "-" : h.Description)</td>
                        <td style="display:flex;gap:6px;flex-wrap:wrap;justify-content:flex-end">
                            <a asp-action="Edit" asp-route-id="@h.Id" class="btn btn-ghost btn-sm">
                                <i class="ti ti-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@h.Id" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this holiday?')">
                                    <i class="ti ti-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">
        <i class="ti ti-alert-circle" style="font-size:16px;margin-right:8px"></i>
        No holidays configured yet.
        <a asp-action="Create" style="margin-left:8px;font-weight:600">Add first holiday</a>
    </div>
}
