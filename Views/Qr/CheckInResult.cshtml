@model BiometricAttendanceSystem.Models.ViewModels.QrCheckInResultVM
@{
    Layout = null;
    ViewData["Title"] = "Check-in Result";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Check-in Result — KP Attendance</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px 16px;
            -webkit-font-smoothing: antialiased;
        }

        body.success { background: #f0fdf4; }
        body.failure  { background: #fff1f2; }

        .card {
            width: 100%;
            max-width: 400px;
            background: #fff;
            border-radius: 20px;
            padding: 36px 28px;
            text-align: center;
            box-shadow: 0 4px 24px rgba(0,0,0,.08);
        }

        .icon { font-size: 60px; line-height: 1; margin-bottom: 16px; }

        .title {
            font-size: 22px;
            font-weight: 800;
            margin-bottom: 8px;
            line-height: 1.2;
        }

        .success .title { color: #15803d; }
        .failure  .title { color: #dc2626; }

        .message {
            font-size: 15px;
            color: #475569;
            margin-bottom: 24px;
            line-height: 1.5;
        }

        .meta-row {
            background: #f8fafc;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 24px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            text-align: left;
        }

        .meta-item { display: flex; justify-content: space-between; align-items: center; font-size: 14px; }
        .meta-label { color: #64748b; font-weight: 500; }
        .meta-value { font-weight: 700; color: #0f172a; }

        .badge {
            display: inline-block;
            padding: 3px 12px;
            border-radius: 99px;
            font-size: 12px;
            font-weight: 700;
        }

        .badge-present { background: #dcfce7; color: #15803d; }
        .badge-late    { background: #fef9c3; color: #92400e; }
        .badge-absent  { background: #fee2e2; color: #dc2626; }

        .btn {
            display: block;
            width: 100%;
            padding: 13px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            text-decoration: none;
            border: none;
            text-align: center;
        }

        .btn-primary { background: #2563eb; color: #fff; }
        .btn-ghost   { background: #f1f5f9; color: #475569; margin-top: 10px; }
    </style>
</head>
<body class="@(Model.Success ? "success" : "failure")">
    <div class="card">
        @if (Model.Success)
        {
            <div class="icon">@(Model.Status == "Late" ? "⚠️" : "✅")</div>
            <div class="title">@(Model.Status == "Late" ? "Late Check-in" : "Checked In!")</div>
            <div class="message">@Model.Message</div>
            <div class="meta-row">
                <div class="meta-item">
                    <span class="meta-label">Name</span>
                    <span class="meta-value">@Model.TeacherName</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Time</span>
                    <span class="meta-value">@Model.CheckInTime</span>
                </div>
                <div class="meta-item">
                    <span class="meta-label">Status</span>
                    <span class="badge badge-@Model.Status?.ToLower()">@Model.Status</span>
                </div>
            </div>
        }
        else
        {
            <div class="icon">❌</div>
            <div class="title">Check-in Failed</div>
            <div class="message">@Model.Message</div>
        }

        <a href="/Teacher/MyAttendance" class="btn btn-primary">View My Attendance</a>
        @if (!Model.Success && Model.FailureReason == "UnknownDevice")
        {
            <a href="/Qr/RegisterDevice" class="btn btn-ghost">Register Device</a>
        }
    </div>
</body>
</html>
