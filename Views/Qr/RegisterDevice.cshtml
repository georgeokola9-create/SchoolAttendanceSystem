@{
    Layout = null;
    ViewData["Title"] = "Register Device";
    var success = ViewBag.Success is bool value && value;
    var error   = ViewBag.Error as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register Device — @ViewBag.SchoolName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f1f5f9;
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px 16px;
            -webkit-font-smoothing: antialiased;
        }

        .card {
            width: 100%;
            max-width: 400px;
            background: #fff;
            border-radius: 20px;
            padding: 36px 28px;
            text-align: center;
            box-shadow: 0 4px 24px rgba(0,0,0,.08);
        }

        .icon-wrap {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: #eff6ff;
            display: grid;
            place-items: center;
            font-size: 30px;
            margin: 0 auto 20px;
        }

        .title   { font-size: 20px; font-weight: 800; color: #0f172a; margin-bottom: 8px; }
        .message { font-size: 14px; color: #475569; line-height: 1.6; margin-bottom: 28px; }

        .alert {
            border-radius: 10px;
            padding: 12px 14px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            text-align: left;
        }

        .alert-success { background: #dcfce7; color: #15803d; border: 1.5px solid #bbf7d0; }
        .alert-danger  { background: #fee2e2; color: #dc2626; border: 1.5px solid #fecaca; }

        .btn {
            display: block;
            width: 100%;
            padding: 13px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            border: none;
            transition: opacity .15s;
        }

        .btn:hover { opacity: .88; }
        .btn-primary { background: #2563eb; color: #fff; margin-bottom: 10px; }
        .btn-ghost   { background: #f1f5f9; color: #475569; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon-wrap">📱</div>

        @if (success)
        {
            <div class="title">Device Registered!</div>
            <div class="alert alert-success">
                ✅ <span>This device is now linked to your account.</span>
            </div>
            <a asp-controller="Teacher" asp-action="MyAttendance" class="btn btn-primary">
                View My Attendance
            </a>
        }
        else if (error == "pending_approval")
        {
            <div class="title">Request Submitted</div>
            <div class="alert" style="background:#fefce8;color:#854d0e;border:1.5px solid #fde68a">
                ⏳ <span>Your device re-registration request has been sent to the admin for approval. You will be able to check in once it is approved.</span>
            </div>
            <a asp-controller="Teacher" asp-action="MyAttendance" class="btn btn-ghost">
                ← Back
            </a>
        }
        else
        {
            <div class="title">Register Device</div>
            <div class="message">
                This browser will be linked to your account for QR attendance check-ins.
                Only registered devices can check in.
            </div>

            @if (!string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger">
                    ⚠️ <span>@error</span>
                </div>
            }

            <form asp-controller="Qr" asp-action="RegisterDevice" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="confirm" value="yes" />
                <button type="submit" class="btn btn-primary">
                    Register This Device
                </button>
            </form>
            <a asp-controller="Teacher" asp-action="MyAttendance" class="btn btn-ghost" style="margin-top:10px">
                ← Back
            </a>
        }
    </div>
</body>
</html>
