{
  "_comment": "Copy this file to appsettings.json and fill in real values. appsettings.json is gitignored and should never be committed.",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=attendance.db"
  },
  "QrToken": {
    "Secret": "REPLACE_WITH_A_RANDOM_SECRET_VALUE"
  },
  "Auth": {
    "PrincipalPassword": "REPLACE_WITH_PRINCIPAL_PASSWORD",
    "Admins": {
      "admin": "REPLACE_WITH_ADMIN_PASSWORD"
    }
  },
  "CheckIn": {
    "AllowedWifiSubnet": "192.168.1",
    "LateAfter": "08:30",
    "CutOffAt": "17:00"
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SenderEmail": "REPLACE_WITH_YOUR_GMAIL_ADDRESS",
    "SenderName": "SchoolBiometricSystem",
    "AppPassword": "REPLACE_WITH_YOUR_EMAIL_APP_PASSWORD"
  }
}
